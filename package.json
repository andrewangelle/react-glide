{
  "name": "react-glide",
  "version": "5.0.0",
  "description": "A multi purpose carousel module built in React.",
  "author": "andrewangelle",
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "repository": "http://github.com/andrewangelle/react-glide.git",
  "license": "MIT",
  "files": [
    "lib",
    "package.json"
  ],
  "type": "module",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.mjs",
      "types": "./lib/index.d.ts"
    },
    "./lib/reactGlide.css": {
      "import": "./lib/reactGlide.css",
      "require": "./lib/reactGlide.css"
    }
  },
  "scripts": {
    "clean": "rimraf lib",
    "build": "pnpm clean && pnpm exec tsdown",
    "build:storybook": "storybook build",
    "start": "storybook dev -p 6006",
    "dev": "storybook dev -p 6006",
    "test": "vitest watch",
    "test:once": "vitest run --coverage",
    "lint:fix": "pnpm biome check . --write",
    "lint:check": "pnpm biome check .",
    "format": "pnpm biome format . --write",
    "pre-commit": "lint-staged",
    "prepare": "husky",
    "ci:publish": "pnpm build && pnpm exec changeset publish",
    "ci:version": "pnpm changeset version",
    "run:example:react18": "pnpm --filter ssr-testing-react-18 dev",
    "run:example:react19": "pnpm --filter ssr-testing-react-19 dev"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "pnpm lint:fix",
      "pnpm format"
    ]
  },
  "keywords": [
    "react",
    "component"
  ],
  "peerDependencies": {
    "react": ">=16.8.x || 17.x.x || 18.x.x || 19.x.x"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@changesets/cli": "^2.29.2",
    "@chromatic-com/storybook": "^5.2.1",
    "@commitlint/cli": "^8.3.6",
    "@commitlint/config-conventional": "^8.3.6",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-links": "^10.4.0",
    "@storybook/react": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@storybook/test": "^8.6.12",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@tsdown/css": "0.22.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@typescript/native-preview": "7.0.0-dev.20260517.1",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.2.4",
    "acorn": "^8.14.1",
    "chromatic": "^11.28.2",
    "cross-env": "^5.2.1",
    "husky": "^9.1.7",
    "jsdom": "^20.0.3",
    "lightningcss": "^1.32.0",
    "lint-staged": "^15.5.1",
    "path": "^0.12.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^6.1.3",
    "source-map-loader": "^0.2.4",
    "storybook": "^10.4.0",
    "tsdown": "^0.22.0",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "happy-dom": "^20.9.0"
  }
}
