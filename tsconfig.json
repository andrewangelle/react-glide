{
  "compilerOptions": {
    "noEmit": true,
    "outDir": "lib",
    "module": "ESNext",
    "target": "ESNext",
    "sourceMap": false,
    "allowJs": false,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
